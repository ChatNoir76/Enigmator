<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

   <extension
         id="application"
         point="org.eclipse.core.runtime.applications">
      <application>
         <run
               class="fr.chatnoir.enigmator.core.Application">
         </run>
      </application>
   </extension>
   <extension
         point="org.eclipse.ui.perspectives">
      <perspective
            class="fr.chatnoir.enigmator.ui.perspective.Perspective"
            name="Perspective"
            id="fr.chatnoir.enigmator.perspective">
      </perspective>
   </extension>
   <extension
         point="org.eclipse.ui.views">
      <view
            class="fr.chatnoir.enigmator.ui.view.View"
            name="View"
            id="fr.chatnoir.enigmator.view"
            inject="true">
      </view>
   </extension>
   <extension
         point="org.eclipse.ui.perspectiveExtensions">
      <perspectiveExtension
            targetID="*">
         <view
               id="fr.chatnoir.enigmator.view"
               minimized="false"
               relationship="left"
               standalone="true"
               relative="org.eclipse.ui.editorss">
         </view>
      </perspectiveExtension>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            locationURI="menu:org.eclipse.ui.main.menu">
         <menu
               id="file"
               label="File">
            <command
                  commandId="org.eclipse.ui.file.exit"
                  label="Exit">
            </command>
         </menu>
      </menuContribution>
      <menuContribution
            locationURI="menu:org.eclipse.ui.main.menu?after=file">
         <menu
               id="edition"
               label="Edition">
            <command
                  commandId="fr.chatnoir.enigmator.conversioncommand"
                  label="Convertir">
            </command>
         </menu>
      </menuContribution>
   </extension>
   <extension
         id="Enigmator"
         point="org.eclipse.core.runtime.products">
      <product
            application="fr.chatnoir.enigmator.application"
            name="Enigmator">
         <property
               name="appName"
               value="Enigmator">
         </property>
      </product>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="fr.chatnoir.enigmator.ui.handler.ConversionHandler"
            commandId="fr.chatnoir.enigmator.conversionhandler">
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            defaultHandler="fr.chatnoir.enigmator.ui.handler.ConversionHandler"
            id="fr.chatnoir.enigmator.conversioncommand"
            name="conversion">
      </command>
   </extension>

</plugin>
